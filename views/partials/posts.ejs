<% if (posts && posts.length> 0) { %>
  <% posts.forEach(post=> { %>
    <div class="card border-0 shadow-sm mb-3" data-post-id="<%= post.id %>">
      <div class="card-body p-3 p-sm-4">
        <!-- User Info -->
        <div class="d-flex align-items-center justify-content-between mb-2">
          <div class="d-flex align-items-center">
            <a href="/@<%- post.username %>">
              <img src="<%- post.profile_pic || '/images/paw.jpg' %>" class="rounded-circle border me-2"
                style="width:40px; height:40px; object-fit:cover;">
            </a>
            <div class="d-flex flex-column">
              <a href="/@<%- post.username %>" class="text-decoration-none text-dark fw-bold mb-0">@<%= post.username %>
                  <!-- <%= post.first_name %> <%= post.last_name %> --></a>
              <a href="/posts/view-post/<%- post.id %>" class="text-decoration-none text-muted small">
                <%= post.created_at ? new Date(post.created_at).toLocaleString() : 'Just now' %>
              </a>
            </div>
          </div>
          <div class="d-flex">
            <a class="btn btn-sm btn-light rounded-circle" href="#" role="button" data-bs-toggle="dropdown"
              aria-expanded="false" style="height:30px;width:30px;border:none;">
              <i class="fa fa-ellipsis"></i>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <% if (post.username !=user.username) { %>
                <li>
                  <a class="dropdown-item" href="#" id="menuReportPost" data-post-id="<%- post.id %>">
                    <i class="fa fa-flag me-2"></i> Report Post
                  </a>
                </li>
                <li>
                  <a class="dropdown-item" href="#" id="menuBlockProfile" data-user-name="<%- post.username %>">
                    <i class="fa fa-user-slash me-2"></i> Block <%= post.username %>
                      <!-- <%= post.first_name %> <%= post.last_name %> -->
                  </a>
                </li>
                <% } else { %>
                  <li>
                    <a class="dropdown-item" href="/posts/delete/<%- post.id %>" id="deletePost"
                      data-post-id="<%- post.id %>">
                      <i class="fa fa-trash me-2"></i> Delete Post
                    </a>
                  </li>
                  <% } %>
            </ul>
          </div>
        </div>

        <!-- Content -->
        <p class="post-text">
          <%= post.content %>
        </p>

        <!-- Media -->
        <% if (post.media && post.media.length> 0) { %>
          <div class="mb-2 post-media-grid <%= post.media.length === 1 ? 'single' : '' %>">
            <% post.media.forEach(url=> { %>
              <% if(url.match(/\.(mp4|mov|avi)$/i)) { %>
                <div class="post-media-item">
                  <video src="<%= url %>" controls playsinline preload="metadata"></video>
                </div>
                <% } else { %>
                  <div class="post-media-item">
                    <img src="<%= url %>" class="img-fluid" alt="Post media">
                  </div>
                  <% } %>
                    <% }) %>
          </div>
          <% } %>

            <!-- Likes + Actions -->
            <div class="d-flex justify-content-between align-items-center mt-3 border-top border-bottom pt-2 pb-2">
              <span class="text-muted small likes-count">
                <% let lCount=(post.likes && Array.isArray(post.likes)) ? post.likes.length : (parseInt(post.likeCount)
                  || 0); %>
                  <%= lCount> 0 ? lCount + ' Likes' : '' %>
              </span>
              <span class="text-muted small comment-count">
                <% let cCount=(post.comments && Array.isArray(post.comments)) ? post.comments.length :
                  (parseInt(post.commentCount) || 0); %>
                  <%= cCount %> Comments
              </span>
            </div>
            <div class="d-flex justify-content-between gap-2 mt-3">
              <button class="btn btn-light btn-sm like-btn flex-fill">
                <i class="<%= post.is_liked ? 'fas text-primary' : 'far' %> fa-thumbs-up me-2"></i> Like
              </button>
              <button class="btn btn-light btn-sm comment-btn flex-fill" data-bs-toggle="modal"
                data-bs-target="#commentModal-<%= post.id %>">
                <i class="far fa-comment me-2"></i> Comment
              </button>
              <button class="btn btn-light btn-sm flex-fill" data-bs-toggle="modal"
                data-bs-target="#shareModal-<%= post.id %>">
                <i class="fas fa-share me-2"></i> Share
              </button>
            </div>
      </div>
    </div>

    <!-- Comment Modal (fullscreen on mobile) -->
    <div class="modal fade" id="commentModal-<%= post.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-lg modal-fullscreen-sm-down">
        <div class="modal-content">

          <!-- Header -->
          <div class="modal-header">
            <h5 class="modal-title">Comments</h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <!-- Body -->
          <div class="modal-body">
            <!-- Comment List -->
            <div class="comments-list" id="comments-list-<%= post.id %>">
              <p class="text-muted">Loading comments...</p>
            </div>

            <!-- Add Comment -->
            <form class="add-comment-form mt-3 d-flex gap-2 flex-nowrap" data-post-id="<%= post.id %>">
              <input type="text" name="comment" class="form-control flex-grow-1" placeholder="Write a comment..."
                required>
              <button class="btn btn-dark flex-shrink-0 px-3" type="submit">Post</button>
            </form>
          </div>

        </div>
      </div>
    </div>

    <!-- Share Modal (fullscreen on mobile) -->
    <div class="modal fade" id="shareModal-<%= post.id %>" tabindex="-1" aria-hidden="true">
      <div class="modal-dialog modal-dialog-centered modal-fullscreen-sm-down">
        <div class="modal-content shadow-lg rounded-3 border-0">

          <!-- Header -->
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-bold text-primary">
              <i class="fas fa-share-alt me-2"></i> Share This Post
            </h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
          </div>

          <div class="modal-body text-center">

            <!-- Internal Share (Repost) -->
            <button class="btn btn-dark w-100 py-2 mb-3 fw-bold share-now-btn" data-post-id="<%= post.id %>">
              <i class="fas fa-retweet me-2"></i> Share Now
            </button>

            <p class="text-muted small mb-2">Or share via...</p>

            <!-- Social Buttons & Copy Link -->
            <div class="d-flex flex-wrap gap-3 justify-content-center">
              <!-- Copy Link -->
              <button
                class="btn btn-outline-secondary rounded-circle p-0 d-flex align-items-center justify-content-center copy-link-btn"
                style="width: 45px; height: 45px;" data-post-id="<%= post.id %>" title="Copy Link">
                <i class="fas fa-link"></i>
              </button>

              <!-- Facebook -->
              <a href="https://www.facebook.com/sharer/sharer.php?u=<%= encodeURIComponent('https://pethudl.com/posts/view-post/' + post.id) %>"
                target="_blank"
                class="btn btn-outline-primary rounded-circle p-0 d-flex align-items-center justify-content-center"
                style="width: 45px; height: 45px; border-color: #1877f2; color: #1877f2;">
                <i class="fab fa-facebook-f"></i>
              </a>

              <!-- Instagram -->
              <a href="https://www.instagram.com/create/story/?url=<%= encodeURIComponent('https://pethudl.com/posts/view-post/' + post.id) %>"
                target="_blank"
                class="btn btn-outline-danger rounded-circle p-0 d-flex align-items-center justify-content-center"
                style="width: 45px; height: 45px; border-color: #e4405f; color: #e4405f;" title="Share to Instagram">
                <i class="fab fa-instagram"></i>
              </a>

              <!-- WhatsApp -->
              <a href="https://wa.me/?text=<%= encodeURIComponent('Check this out: https://pethudl.com/posts/view-post/' + post.id) %>"
                target="_blank"
                class="btn btn-outline-success rounded-circle p-0 d-flex align-items-center justify-content-center"
                style="width: 45px; height: 45px; border-color: #25d366; color: #25d366;">
                <i class="fab fa-whatsapp"></i>
              </a>

              <!-- X (Twitter) -->
              <a href="https://x.com/intent/tweet?url=<%= encodeURIComponent('https://pethudl.com/posts/view-post/' + post.id) %>&text=<%= encodeURIComponent('Check this out!') %>"
                target="_blank"
                class="btn btn-outline-dark rounded-circle p-0 d-flex align-items-center justify-content-center"
                style="width: 45px; height: 45px;">
                <i class="fab fa-x-twitter"></i>
              </a>
            </div>

            <!-- Hidden input for copy functionality -->
            <input type="text" id="postLink-<%= post.id %>"
              value="<%= 'https://pethudl.com/posts/view-post/' + post.id %>" class="visually-hidden">

          </div>

        </div>
      </div>
    </div>

    <% }) %>
      <% } else { %>
        <p class="text-center text-muted mt-3">No posts yet</p>
        <% } %>


          <script>
            document.addEventListener('DOMContentLoaded', () => {
              // LIKE BUTTON
              document.querySelectorAll('.like-btn').forEach(btn => {
                btn.addEventListener('click', async () => {
                  const card = btn.closest('[data-post-id]');
                  const postId = card.dataset.postId;
                  try {
                    const res = await fetch(`/posts/${postId}/like`, { method: 'POST' });
                    const data = await res.json();
                    if (data.success) {
                      // Update like count
                      const countEl = card.querySelector('.likes-count');
                      let currentLikes = parseInt(countEl.textContent) || 0;
                      if (data.liked) {
                        currentLikes++;
                        // make solid
                        btn.querySelector('i').classList.remove('far');
                        btn.querySelector('i').classList.add('fas', 'text-primary');
                      } else {
                        currentLikes--;
                        // revert back to outline
                        btn.querySelector('i').classList.remove('fas', 'text-primary');
                        btn.querySelector('i').classList.add('far');
                      }
                      countEl.textContent = currentLikes > 0 ? `${currentLikes} Likes` : '';
                    }
                  } catch (err) {
                    console.error('Error liking post:', err);
                  }
                });
              });

              // Function to load comments for a post
              async function loadComments(postId) {
                const listEl = document.getElementById(`comments-list-${postId}`);
                listEl.innerHTML = '<p class="text-muted">Loading comments...</p>';
                try {
                  const res = await fetch(`/posts/${postId}/comments`);
                  const data = await res.json();
                  const comments = Array.isArray(data.comments) ? data.comments : [];
                  if (comments.length > 0) {
                    listEl.innerHTML = comments.map(c => `
          <div class="d-flex mb-2 align-items-start">
            <a href="/@${c.username}">
              <img src="${c.profile_pic || '/images/paw.jpg'}" 
                   class="rounded-circle border me-2" 
                   style="width:40px; height:40px; object-fit:cover;">
            </a>
            <div class="flex-fill">
                <div class="d-flex flex-column bg-light rounded-4 p-2">
                    <p class="m-0 fw-bold small">@${c.username}</p>
                    <p class="m-0 comment-text">${c.comment}</p>
                </div>
                <div class="d-flex align-items-center gap-1">
                    <span class="text-muted small"><small>${new Date(c.created_at).toLocaleString()}</span></small>
                    ${c.can_delete ? `<a href="#" class="text-decoration-none text-muted delete-comment small fw-bold" data-comment-id="${c.id}" data-post-id="${postId}"><span class="small">Delete</span></a>` : ''}
                </div>
            </div>
          </div>
      `).join('');
                  } else {
                    listEl.innerHTML = '<p class="text-muted">No comments yet</p>';
                  }
                } catch (err) {
                  console.error('Error loading comments:', err);
                }
              }

              // LOAD COMMENTS WHEN MODAL OPENS
              document.querySelectorAll('.comment-btn').forEach(btn => {
                btn.addEventListener('click', () => {
                  const postId = btn.closest('[data-post-id]').dataset.postId;
                  loadComments(postId);
                });
              });

              // ADD COMMENT
              document.querySelectorAll('.add-comment-form').forEach(form => {
                form.addEventListener('submit', async e => {
                  e.preventDefault();
                  const postId = form.dataset.postId;
                  const input = form.querySelector('input[name="comment"]');
                  const comment = input.value.trim();
                  if (!comment) return;

                  try {
                    const res = await fetch(`/posts/${postId}/comment`, {
                      method: 'POST',
                      headers: { 'Content-Type': 'application/json' },
                      body: JSON.stringify({ comment })
                    });
                    const data = await res.json();
                    if (data.success) {
                      input.value = '';
                      loadComments(postId); // ✅ directly reload comments
                    }
                  } catch (err) {
                    console.error('Error adding comment:', err);
                  }
                });
              });

              // DELETE COMMENT (delegated event)
              document.body.addEventListener('click', async e => {
                const target = e.target.closest('.delete-comment');
                if (!target) return;

                const commentId = target.dataset.commentId;
                const postId = target.dataset.postId;

                if (!commentId) {
                  console.error('No comment ID found');
                  return;
                }
                if (!postId) {
                  console.error('No post ID found');
                  return;
                }

                if (!confirm('Delete this comment?')) return;

                try {
                  const res = await fetch(`/posts/comment/${encodeURIComponent(commentId)}?postId=${encodeURIComponent(postId)}`, { method: 'DELETE' });
                  const data = await res.json();
                  if (data.success) {
                    // ✅ Directly reload comments instead of simulating button click
                    await loadComments(postId);

                    // ✅ Update comment count in the main post
                    const card = document.querySelector(`[data-post-id="${postId}"]`);
                    const commentCountEl = card.querySelector('.comment-count');
                    let currentComments = parseInt(commentCountEl.textContent) || 0;
                    if (currentComments > 0) {
                      currentComments--;
                      commentCountEl.textContent = `${currentComments} Comments`;
                    }
                  }
                } catch (err) {
                  console.error('Error deleting comment:', err);
                }
              });

              // DELETE POST (delegated event)
              document.body.addEventListener('click', async e => {
                if (e.target.closest('#deletePost')) {
                  e.preventDefault();
                  const btn = e.target.closest('#deletePost');
                  const postCard = btn.closest('[data-post-id]');
                  const postId = postCard.dataset.postId;

                  if (!confirm('🗑️ Are you sure you want to delete this post?')) return;

                  try {
                    const res = await fetch(`/posts/delete/${postId}`, { method: 'DELETE' });
                    const data = await res.json();
                    if (data.success) {
                      // ✅ remove card from DOM
                      postCard.remove();
                    } else {
                      alert(data.message || 'Failed to delete post');
                    }
                  } catch (err) {
                    console.error('Error deleting post:', err);
                    alert('Error deleting post');
                  }
                }
              });

              // COPY LINK
              document.body.addEventListener('click', e => {
                const btn = e.target.closest('.copy-link-btn');
                if (!btn) return;

                const postId = btn.dataset.postId;
                const input = document.getElementById(`postLink-${postId}`);

                // Create temp input if hidden
                if (input.classList.contains('visually-hidden')) {
                  navigator.clipboard.writeText(input.value);
                } else {
                  input.select();
                  input.setSelectionRange(0, 99999);
                  navigator.clipboard.writeText(input.value);
                }

                // Visual feedback
                const icon = btn.querySelector('i');
                const orgClass = icon.className;
                icon.className = 'fas fa-check';
                setTimeout(() => icon.className = orgClass, 2000);
              });

              // SHARE NOW (Internal)
              document.body.addEventListener('click', async e => {
                const btn = e.target.closest('.share-now-btn');
                if (!btn) return;

                const postId = btn.dataset.postId;
                const originalText = btn.innerHTML;

                if (!confirm('Share this post to your feed?')) return;

                btn.disabled = true;
                btn.innerHTML = '<span class="spinner-border spinner-border-sm" role="status" aria-hidden="true"></span> Sharing...';

                try {
                  const res = await fetch(`/posts/${postId}/share`, { method: 'POST' });
                  const data = await res.json();

                  if (data.success) {
                    alert('Post shared successfully!');
                    // Close modal
                    const modalEl = btn.closest('.modal');
                    const modalInstance = bootstrap.Modal.getInstance(modalEl);
                    modalInstance.hide();

                    // Optional: reload to see new post, or just stay
                    window.location.reload();
                  } else {
                    alert(data.message || 'Failed to share post');
                    btn.innerHTML = originalText;
                    btn.disabled = false;
                  }
                } catch (err) {
                  console.error('Error sharing post:', err);
                  alert('Error sharing post');
                  btn.innerHTML = originalText;
                  btn.disabled = false;
                }
              });

            });
          </script>